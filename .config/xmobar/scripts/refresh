#!/usr/bin/env bash

source "${HOME}/.config/barlib/scripts/env"

PIDFILE="${BAR_DIR}/.cache/bar-daemon.pid"

if [[ -f "$PIDFILE" ]]; then
  pid=$(< "$PIDFILE")
  if kill -0 "$pid" 2>/dev/null; then
    kill -USR1 "$pid"
    exit 0
  fi
fi

# Daemon not running — fall back to launching it
# (xmobar should have started it, but just in case)
"${BAR_DIR}/scripts/bar-daemon" &
