#!/usr/bin/env bash

source "${HOME}/.config/barlib/scripts/env"

CACHE_DIR="${BAR_DIR}/.cache"
mkdir -p "$CACHE_DIR"

CACHE_FILE="${CACHE_DIR}/bar_output"
TRIGGER_FILE="${CACHE_DIR}/refresh_trigger"

spinner_active=0
# STATE_FILE comes from env

# Check for any *_live=1 in state file (live states bypass cache)
if grep -qE "^[a-z_]*_live=\"?1\"?$" "$STATE_FILE" 2>/dev/null; then
  spinner_active=1
fi

# Fast path: cache hit — just output and exit
if [[ $spinner_active -eq 0 && -f "$CACHE_FILE" && -f "$TRIGGER_FILE" && "$CACHE_FILE" -nt "$TRIGGER_FILE" ]]; then
  cat "$CACHE_FILE"
  exit 0
fi

set -a
source "${BAR_COMPONENTS_DIR}/scripts/vars"
source "${STATE_FILE}"
set +a

[[ ! -f "$TRIGGER_FILE" ]] && touch "$TRIGGER_FILE"

components=(
  #"capslock"
  "updates"
  "volume"
  "volume_output"
  "brightness"
  "bluetooth"
  "battery"
  "space"
  "vpn"
  "network"
  "cpu_temp"
  "sys_usage"
  "weather"
  "speedtest"
  "rofi_theme"
  "yt_dl"
  "wallpaper"
  "screenshot"
  "automount"
  "page"
  #"calendar"
  #"power"
)

# Run all components in parallel, preserving order via temp files
RENDER_TMP="${CACHE_DIR}/render_tmp"
# Clean up from any previous run before starting
rm -rf "$RENDER_TMP"
mkdir -p "$RENDER_TMP"

pids=()
for i in "${!components[@]}"; do
  component="${components[$i]}"
  outfile="${RENDER_TMP}/${i}"
  # Touch first so cat never fails on empty-output components
  : > "$outfile"
  "${BAR_DIR}/com/${component}/render" > "$outfile" 2>/dev/null &
  pids+=($!)
done

# Wait for all to finish
for pid in "${pids[@]}"; do
  wait "$pid"
done

# Concatenate in order
bar=""
for i in "${!components[@]}"; do
  bar+="$(cat "${RENDER_TMP}/${i}")"
done

printf '%s\n' "$bar" | tee "$CACHE_FILE"
