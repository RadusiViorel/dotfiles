#!/usr/bin/env bash

source "${HOME}/.config/barlib/scripts/env"
source "${BAR_COMPONENTS_DIR}/scripts/check_dependency"
check_dependency "yad" --no-exit

COM="${BAR_COMPONENTS_DIR}/com/calendar"
[[ -n "$1" ]] && source "${STATE_FILE}"

source "${BAR_COMPONENTS_DIR}/scripts/vars"
source "${BAR_COMPONENTS_DIR}/scripts/tuples"
source "${BAR_COMPONENTS_DIR}/scripts/state_loader"

state_init "calendar_toggle" 0

case "$1" in
  toggle) ${COM}/actions/toggle              \
    --value=${calendar_toggle}               \
    --STATE_FILE=${STATE_FILE}               \
    --KEY=calendar_toggle ;;
  show_calendar) ${COM}/actions/show_calendar ;;
  *) ;;
esac

declare -A ICONS=(
  [00]="оҺҒ" [01]="оҺӮ" [02]="оҺғ" [03]="оҺ„" [04]="оҺ…" [05]="оҺҶ"
  [06]="оҺҮ" [07]="оҺҲ" [08]="оҺү" [09]="оҺҠ" [10]="оҺӢ" [11]="оҺҢ"
  [12]="уұ‘Ҡ" [13]="уұҗҝ" [14]="уұ‘Җ" [15]="уұ‘Ғ" [16]="уұ‘Ӯ" [17]="уұ‘ғ"
  [18]="уұ‘„" [19]="уұ‘…" [20]="уұ‘Ҷ" [21]="уұ‘Ү" [22]="уұ‘Ҳ" [23]="уұ‘ү"
)

if [[ $calendar_toggle -eq 1 ]]; then
  emit_tuple 0 "$COLOR_WARNING" "оӘ° "
  emit_tuple 0 "$COLOR_WARNING" "$(date +"%d-%m-%Y")"
else
  emit_tuple 1 "$COLOR_OK" "${ICONS[$(date +%H)]}"
  emit_tuple 0 "$COLOR_OK" " $(date +"%H:%M:%S")"
fi
emit_sep
