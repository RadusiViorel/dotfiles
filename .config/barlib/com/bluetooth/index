#!/usr/bin/env bash

source "${HOME}/.config/barlib/scripts/init"
source "${BAR_COMPONENTS_DIR}/scripts/check_dependency"
check_dependency "bluetoothctl"
check_dependency "upower"
check_dependency "bluetuith" --no-exit

COM="${BAR_COMPONENTS_DIR}/com/bluetooth"
[[ -n "$1" ]] && source "${STATE_FILE}"
page_guard 1

source "${BAR_COMPONENTS_DIR}/scripts/cache"

state_init "bluetooth_index_device" -1

state=$(bluetoothctl show | awk '/Powered/ {print ($2=="yes"?1:0)}')
disabledColor="$COLOR_MUTE"
thresholds=(10 33 66)
timercolors=("$COLOR_CRITIC" "$COLOR_DANGER" "$COLOR_WARNING" "$COLOR_OK")
outputColor="$COLOR_WHITE"

mapfile -t connectedDevices < <(
  bluetoothctl devices Connected | sed 's/^Device [A-F0-9:]* //'
)

if [ ${#connectedDevices[@]} -eq 0 ]; then
  state_update "bluetooth_index_device" -1
fi

case "$1" in
  open)      ${COM}/actions/open ;;
  toggle)    ${COM}/actions/toggle \
    --state=${state} ;;
  reset)     ${COM}/actions/reset    \
    --STATE_FILE=${STATE_FILE}       \
    --KEY=bluetooth_index_device ;;
  cycle_up)  ${COM}/actions/cycle_up \
    --STATE_FILE=${STATE_FILE}       \
    --KEY=bluetooth_index_device     \
    --currentIndex=${bluetooth_index_device} \
    --count=${#connectedDevices[@]} ;;
  cycle_down) ${COM}/actions/cycle_down \
    --STATE_FILE=${STATE_FILE}          \
    --KEY=bluetooth_index_device        \
    --currentIndex=${bluetooth_index_device} \
    --count=${#connectedDevices[@]} ;;
  *) ;;
esac

# Re-read state after action may have updated it
source "${STATE_FILE}"

if [[ $bluetooth_index_device -eq -1 ]]; then
  connectedCount=${#connectedDevices[@]}
  if   [ "$connectedCount" -eq 1 ]; then label=" ${connectedCount} device"
  elif [ "$connectedCount" -eq 0 ]; then label=""
  else                                    label=" ${connectedCount} devices"
  fi
else
  percentage=$(upower --dump | awk -v name="${connectedDevices[$bluetooth_index_device]}" '
    /^ *model:/ {
      $1=""; sub(/^ +/, "", $0)
      if ($0 == name) found=1
    }
    found && /percentage:/ { gsub("%","",$2); print $2; exit }
  ')
  [[ -z "$percentage" ]] && percentage=100

  outputColor="${timercolors[${#timercolors[@]}-1]}"
  for i in "${!thresholds[@]}"; do
    if (( percentage < thresholds[i] )); then
      outputColor="${timercolors[$i]}"
      break
    fi
  done
  label=" $((bluetooth_index_device + 1))/${#connectedDevices[@]} ${connectedDevices[$bluetooth_index_device]} ${percentage}󰏰"
fi

icons=("󰂲" "󰂰")
colors=("$disabledColor" "$outputColor")

emit_tuple 0 "${colors[$state]}" "${icons[$state]}${label}"
emit_sep
