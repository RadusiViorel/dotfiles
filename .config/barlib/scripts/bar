#!/usr/bin/env bash

source "${HOME}/.config/barlib/scripts/env"

CACHE_DIR="${BAR_DIR}/.cache"
mkdir -p "$CACHE_DIR"

CACHE_FILE="${CACHE_DIR}/bar_output"
TRIGGER_FILE="${CACHE_DIR}/refresh_trigger"

spinner_active=0
# STATE_FILE comes from env

# Check for any *_live=1 in state file (live states bypass cache)
if grep -q "^[a-z_]*_live=1$" "$STATE_FILE" 2>/dev/null; then
  spinner_active=1
fi

# Fast path: if cache exists and is newer than trigger AND no live state is active, just output it
if [[ $spinner_active -eq 0 && -f "$CACHE_FILE" && -f "$TRIGGER_FILE" && "$CACHE_FILE" -nt "$TRIGGER_FILE" ]]; then
  cat "$CACHE_FILE"
  exit 0
fi

set -a  # Auto-export all variables
source "${BAR_COMPONENTS_DIR}/scripts/vars"
source "${STATE_FILE}"
set +a

[[ ! -f "$TRIGGER_FILE" ]] && touch "$TRIGGER_FILE"

# Resolve component: bar-local override takes priority over barlib shared
resolve_render() {
  local component="$1"
  if [[ -f "${BAR_DIR}/com/${component}/render" ]]; then
    echo "${BAR_DIR}/com/${component}/render"
  else
    echo "${BAR_COMPONENTS_DIR}/com/${component}/render"
  fi
}

components=(
  #"capslock"
  "updates"
  "volume"
  "volume_output"
  "brightness"
  "bluetooth"
  "battery"
  "space"
  "vpn"
  "network"
  "cpu_temp"
  "sys_usage"
  "weather"
  "speedtest"
  "rofi_theme"
  "yt_dl"
  "wallpaper"
  "screenshot"
  "automount"
  "page"
  #"calendar"
  #"power"
)

bar=""
for component in "${components[@]}"; do
  bar+="$($(resolve_render "$component"))"
done

printf '%s\n' "$bar" | tee "$CACHE_FILE"
