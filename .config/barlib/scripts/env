#!/usr/bin/env bash
# Bar environment defaults — override by exporting before sourcing this file.
# Each bar's launch mechanism should export these before anything runs.

export BAR_DIR="${BAR_DIR:-${HOME}/.config/xmobar}"
export BAR_COMPONENTS_DIR="${BAR_COMPONENTS_DIR:-${HOME}/.config/barlib}"
export BAR_NAME="${BAR_NAME:-xmobar}"
export REFRESH_CMD="${REFRESH_CMD:-${BAR_DIR}/scripts/refresh}"
export STATE_FILE="${STATE_FILE:-${BAR_COMPONENTS_DIR}/scripts/state}"

# Resolve a component file: bar-local override takes priority over barlib shared.
# Usage: resolve_component <component> <file>  (e.g. resolve_component "battery" "index")
resolve_component() {
  local component="$1"
  local file="${2:-index}"
  local local_path="${BAR_DIR}/com/${component}/${file}"
  if [[ -f "$local_path" ]]; then
    echo "$local_path"
  else
    echo "${BAR_COMPONENTS_DIR}/com/${component}/${file}"
  fi
}

# Start a live-watcher spinner for a module while an async operation runs.
# Calls $BAR_DIR/scripts/live-watcher if it exists; no-op otherwise.
# Usage: start_live_watcher <module> <state-key>
start_live_watcher() {
  local watcher="${BAR_DIR}/scripts/live-watcher"
  if [[ -x "$watcher" ]]; then
    "$watcher" "$1" "$2" &
  fi
}
