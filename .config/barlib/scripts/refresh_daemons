#!/usr/bin/env bash
# Master script to manage all component refresh daemons
# Called from xinitrc to start/stop all auto-refresh components

source "${HOME}/.config/barlib/scripts/env"

# Resolve component: bar-local override takes priority over barlib shared
resolve_com() {
  local component="$1"
  local file="$2"
  if [[ -f "${BAR_DIR}/com/${component}/${file}" ]]; then
    echo "${BAR_DIR}/com/${component}/${file}"
  else
    echo "${BAR_COMPONENTS_DIR}/com/${component}/${file}"
  fi
}

# List of components that have refresh daemons
COMPONENTS=(
  "sys_usage"
  "battery"
)

case "$1" in
  start)
    echo "Starting bar refresh daemons..."
    for component in "${COMPONENTS[@]}"; do
      refresh_script=$(resolve_com "$component" "refresh")
      if [[ -x "$refresh_script" ]]; then
        "$refresh_script" start
      fi
    done
    echo "All refresh daemons started" ;;

  stop)
    echo "Stopping bar refresh daemons..."
    for component in "${COMPONENTS[@]}"; do
      refresh_script=$(resolve_com "$component" "refresh")
      if [[ -x "$refresh_script" ]]; then
        "$refresh_script" stop
      fi
    done
    echo "All refresh daemons stopped" ;;

  restart)
    echo "Restarting bar refresh daemons..."
    "$0" stop
    sleep 1
    "$0" start ;;

  status)
    echo "Bar refresh daemon status:"
    for component in "${COMPONENTS[@]}"; do
      refresh_script=$(resolve_com "$component" "refresh")
      if [[ -x "$refresh_script" ]]; then
        "$refresh_script" status
      fi
    done ;;

  *)
    echo "Usage: $0 {start|stop|restart|status}"
    echo ""
    echo "Manages refresh daemons for time-based bar components:"
    for component in "${COMPONENTS[@]}"; do
      echo "  - $component"
    done
    exit 1 ;;
esac
